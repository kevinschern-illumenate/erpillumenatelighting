{
  "version": "1.0",
  "_comment": "NON-ENGINEER EDITABLE. Each item in `questions` is one wizard step. `lumensBands` is a configurator heuristic (NOT an ERP field) mapping fixture purpose -> a target lumens/ft range used only for ranking. See README 'How to add a question'.",
  "lumensBands": {
    "_comment": "Configurator heuristic only. lumens_per_foot is a real ERP field, but the accent/task/ambient banding is our own and must not be presented as an ERP spec value.",
    "Accent": { "min": 150, "max": 300, "label": "Accent (~150\u2013300 lm/ft)" },
    "Task": { "min": 300, "max": 500, "label": "Task (~300\u2013500 lm/ft)" },
    "Ambient": { "min": 500, "max": 99999, "label": "Ambient (~500+ lm/ft)" }
  },
  "questions": [
    {
      "id": "indoor_outdoor",
      "label": "Is this an indoor or outdoor installation?",
      "glossaryKey": "indoor_outdoor",
      "type": "single",
      "required": true,
      "options": [
        { "value": "Indoor", "label": "Indoor", "imageId": "indoor-outdoor-indoor", "color": "#fef5e7" },
        { "value": "Outdoor", "label": "Outdoor", "glossaryKey": "wet_rating", "imageId": "indoor-outdoor-outdoor", "color": "#fff3cd" }
      ]
    },
    {
      "id": "moisture",
      "label": "What moisture exposure will the location see?",
      "glossaryKey": "environment_rating",
      "type": "single",
      "required": true,
      "filters": { "attribute": "environment_rating" },
      "options": [
        { "value": "Dry", "label": "Dry", "imageId": "moisture-dry", "color": "#f9e79f" },
        { "value": "Damp", "label": "Damp", "imageId": "moisture-damp", "color": "#d6eaf8" },
        { "value": "Wet", "label": "Wet", "imageId": "moisture-wet", "color": "#a9ccf0" }
      ]
    },
    {
      "id": "ip_rating",
      "label": "What IP (ingress protection) rating do you need?",
      "glossaryKey": "ip_rating",
      "type": "single",
      "required": true,
      "filters": { "attribute": "ip_rating" },
      "visibleWhen": { "any": [{ "q": "moisture", "in": ["Damp", "Wet"] }] },
      "skipWhen": { "any": [{ "q": "moisture", "eq": "Dry" }] },
      "options": [
        { "value": "IP65", "label": "IP65 — water jets", "imageId": "ip-rating-ip65", "color": "#aed6f1" },
        { "value": "IP67", "label": "IP67 — temporary immersion", "imageId": "ip-rating-ip67", "color": "#7fb3d5" },
        { "value": "IP68", "label": "IP68 — continuous immersion", "imageId": "ip-rating-ip68", "color": "#5499c7" }
      ]
    },
    {
      "id": "light_type",
      "label": "What type of light do you need?",
      "glossaryKey": "light_type",
      "type": "single",
      "required": true,
      "filters": { "attribute": "light_type" },
      "options": [
        { "value": "Static white", "label": "Static White", "color": "linear-gradient(135deg, #fffde7 0%, #fff9c4 50%, #fffef5 100%)" },
        { "value": "Tunable white", "label": "Tunable White", "color": "linear-gradient(90deg, #ffd580 0%, #fff8e7 40%, #e8f4ff 70%, #b3d9ff 100%)" },
        { "value": "Dim-to-warm", "label": "Dim-to-Warm", "color": "linear-gradient(135deg, #ff6f00 0%, #ffa726 20%, #ffe79c 100%)" },
        { "value": "Full-color", "label": "Full-color (RGBW / RGB+TW / Pixel)", "color": "linear-gradient(135deg, #ff4081 0%, #ff6e40 20%, #ffea00 40%, #69f0ae 60%, #40c4ff 80%, #e040fb 100%)" }
      ]
    },
    {
      "id": "color_mode",
      "label": "How should the color be controlled?",
      "glossaryKey": "color_mode",
      "type": "single",
      "required": true,
      "filters": { "attribute": "dimming_protocol" },
      "visibleWhen": { "all": [{ "q": "light_type", "eq": "Full-color" }] },
      "options": [
        { "value": "Analog RGB/RGBW", "label": "Analog RGB / RGBW (one color at a time)", "imageId": "color-mode-analog-rgb", "color": "linear-gradient(135deg, #ff4081 0%, #ff6e40 20%, #ffea00 40%, #69f0ae 60%, #40c4ff 80%, #e040fb 100%)" },
        { "value": "Addressable pixel (SPI)", "label": "Addressable pixel (SPI — per-pixel effects)", "imageId": "color-mode-addressable-pixel", "color": "linear-gradient(90deg, #00bcd4, #03a9f4, #2196f3)" }
      ]
    },
    {
      "id": "fixture_purpose",
      "label": "What is the primary purpose of this fixture?",
      "glossaryKey": "fixture_purpose",
      "type": "single",
      "required": true,
      "derives": { "band": "lumensBands" },
      "options": [
        { "value": "Accent", "label": "Accent — highlight an object or edge", "imageId": "fixture-purpose-accent", "color": "#ffc107" },
        { "value": "Task", "label": "Task — light a work surface", "imageId": "fixture-purpose-task", "color": "#ffffff" },
        { "value": "Ambient", "label": "Ambient — fill a room", "imageId": "fixture-purpose-ambient", "color": "#fff9c4" }
      ]
    },
    {
      "id": "installation_method",
      "label": "How will the fixture be installed?",
      "glossaryKey": "installation_method",
      "type": "single",
      "required": true,
      "filters": { "attribute": "mounting_method" },
      "options": [
        { "value": "Surface", "label": "Surface mount", "imageId": "installation-method-surface", "color": "#e8f4f8" },
        { "value": "Recessed", "label": "Recessed", "imageId": "installation-method-recessed", "color": "#f0f0f0" },
        { "value": "Angled", "label": "Angled / corner", "imageId": "installation-method-angled", "color": "#ffe8cc" },
        { "value": "Drywall-plaster-in", "label": "Drywall / plaster-in (trimless)", "imageId": "installation-method-drywall-plaster-in", "color": "#f5f5f5" },
        { "value": "Suspended", "label": "Suspended", "imageId": "installation-method-suspended", "color": "#e8e8f8" }
      ]
    },
    {
      "id": "target_cct",
      "label": "What color temperature (CCT) do you want?",
      "glossaryKey": "target_cct",
      "type": "single",
      "required": true,
      "filters": { "attribute": "cct" },
      "visibleWhen": { "all": [{ "q": "light_type", "in": ["Static white", "Dim-to-warm"] }] },
      "skipWhen": { "any": [{ "q": "light_type", "eq": "Full-color" }] },
      "options": [
        { "value": "2700K", "label": "2700K — warm", "color": "#ff9800" },
        { "value": "3000K", "label": "3000K — warm-neutral", "color": "#ffc107" },
        { "value": "3500K", "label": "3500K — neutral", "color": "#ffeb3b" },
        { "value": "4000K", "label": "4000K — cool", "color": "#e3f2fd" }
      ]
    },
    {
      "id": "cct_range",
      "label": "Select the tunable white range you need.",
      "glossaryKey": "target_cct",
      "type": "range",
      "required": true,
      "filters": { "attribute": "cct" },
      "visibleWhen": { "all": [{ "q": "light_type", "eq": "Tunable white" }] },
      "min": 2700,
      "max": 4000,
      "step": 100,
      "unit": "K",
      "defaultLow": 2700,
      "defaultHigh": 4000
    },
    {
      "id": "cri",
      "label": "What color rendering (CRI) do you require?",
      "glossaryKey": "cri",
      "type": "single",
      "required": true,
      "filters": { "attribute": "cri" },
      "options": [
        { "value": "90+", "label": "90+ (standard architectural)", "color": "#f5f5f5" },
        {
          "value": "95+",
          "label": "95+ (premium)",
          "note": "Limited availability — confirm before committing.",
          "color": "#fafafa"
        }
      ]
    },
    {
      "id": "run_length",
      "label": "How long is the continuous run?",
      "glossaryKey": "run_length",
      "type": "number",
      "required": true,
      "min": 1,
      "max": 500,
      "step": 1,
      "unit": "ft",
      "placeholder": "e.g. 24"
    },
    {
      "id": "continuous_run",
      "label": "Is this one continuous, unbroken run?",
      "glossaryKey": "run_length",
      "type": "single",
      "required": false,
      "options": [
        { "value": "Yes", "label": "Yes — one continuous run", "imageId": "continuous-run-yes", "color": "#c8e6c9" },
        { "value": "No", "label": "No — multiple segments", "imageId": "continuous-run-no", "color": "#ffccbc" }
      ]
    },
    {
      "id": "power_injection",
      "label": "Power feed summary",
      "glossaryKey": "power_injection",
      "type": "info",
      "required": false,
      "visibleWhen": { "all": [{ "q": "run_length", "gt": 0 }] }
    },
    {
      "id": "supply_voltage",
      "label": "What supply voltage is available?",
      "glossaryKey": "supply_voltage",
      "type": "single",
      "required": true,
      "skipWhen": { "_note": "TEMP: hardcoded to 24VDC — delete this skipWhen block to re-enable the question", "all": [] },
      "filters": { "attribute": "input_voltage" },
      "options": [
        { "value": "24VDC", "label": "24VDC (low-voltage)", "imageId": "supply-voltage-24vdc", "color": "#bbdefb" },
        { "value": "120VAC", "label": "120VAC (line-voltage)", "imageId": "supply-voltage-120vac", "color": "#fff9c4" }
      ]
    },
    {
      "id": "dimming_protocol",
      "label": "Which dimming / control protocol will you use?",
      "glossaryKey": "dimming_protocol",
      "type": "single",
      "required": true,
      "filters": { "attribute": "dimming_protocol" },
      "options": [
        { "value": "0-10V", "label": "0-10V", "hideWhen": { "any": [{ "q": "color_mode", "eq": "Addressable pixel (SPI)" }] }, "imageId": "dimming-protocol-0-10v", "color": "linear-gradient(90deg, #c5cae9, #9fa8da)" },
        { "value": "TRIAC", "label": "TRIAC", "hideWhen": { "any": [{ "q": "color_mode", "eq": "Addressable pixel (SPI)" }] }, "imageId": "dimming-protocol-triac", "color": "#e0e0e0" },
        { "value": "ELV", "label": "ELV", "hideWhen": { "any": [{ "q": "color_mode", "eq": "Addressable pixel (SPI)" }] }, "imageId": "dimming-protocol-elv", "color": "#e8d7e8" },
        { "value": "DALI", "label": "DALI", "hideWhen": { "any": [{ "q": "color_mode", "eq": "Addressable pixel (SPI)" }] }, "imageId": "dimming-protocol-dali", "color": "#c8e6c9" },
        { "value": "DMX512", "label": "DMX512", "imageId": "dimming-protocol-dmx512", "color": "#ffccbc" },
        { "value": "SPI", "label": "SPI (addressable pixel)", "imageId": "dimming-protocol-spi", "color": "linear-gradient(90deg, #00bcd4, #03a9f4, #2196f3)" }
      ]
    },
    {
      "id": "diffuser",
      "label": "What diffuser / lens appearance do you want?",
      "glossaryKey": "diffuser",
      "type": "single",
      "required": true,
      "filters": { "attribute": "lens_appearance" },
      "options": [
        { "value": "Clear", "label": "Clear (brightest)", "imageId": "diffuser-clear", "color": "linear-gradient(135deg, #f0f8ff 0%, #e6f3ff 100%)" },
        { "value": "Frosted", "label": "Frosted (hides dots)", "imageId": "diffuser-frosted", "color": "#f5f5f5" },
        { "value": "White", "label": "White (fully diffused)", "imageId": "diffuser-white", "color": "#ffffff" },
        { "value": "Black", "label": "Black (stealth daytime)", "imageId": "diffuser-black", "color": "#212121" }
      ]
    },
    {
      "id": "operating_temp",
      "label": "What is the ambient operating temperature? (optional)",
      "glossaryKey": "operating_temp",
      "type": "number",
      "required": false,
      "min": -40,
      "max": 80,
      "step": 1,
      "unit": "\u00b0C",
      "placeholder": "e.g. 25"
    },
    {
      "id": "finish",
      "label": "What channel finish do you prefer? (optional)",
      "glossaryKey": "finish",
      "type": "single",
      "required": false,
      "filters": { "attribute": "finish" },
      "options": [
        { "value": "Silver", "label": "Silver", "imageId": "finish-silver", "color": "#c0c0c0" },
        { "value": "Black", "label": "Black", "imageId": "finish-black", "color": "#212121" },
        { "value": "White", "label": "White", "imageId": "finish-white", "color": "#ffffff" }
      ]
    }
  ]
}
